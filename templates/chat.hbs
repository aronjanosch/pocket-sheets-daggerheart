{{!-- Chat mode: the table message log. Each message is rendered via Foundry's own
      message.getHTML() so system roll cards, item posts, and enriched content all
      display identically to the normal sidebar — no custom parser needed. --}}
<div class="ms-body ms-chat-scroll">
  {{#if chat.empty}}
    <div class="ms-chat-empty">{{localize "MOBILE_SHEET.chat.empty"}}</div>
  {{/if}}

  {{#each chat.messages}}
    {{#if this.nativeHtml}}
      <div class="ms-native-msg">{{{this.nativeHtml}}}</div>
    {{/if}}
  {{/each}}
</div>

<div class="ms-compose">
  <input type="text" class="ms-compose-input" inputmode="text" autocomplete="off"
         placeholder="{{localize "MOBILE_SHEET.chat.placeholder"}}" />
  <button type="button" class="ms-compose-send" data-action="sendChat"
          title="{{localize "MOBILE_SHEET.chat.send"}}"
          aria-label="{{localize "MOBILE_SHEET.chat.send"}}">➤</button>
</div>
